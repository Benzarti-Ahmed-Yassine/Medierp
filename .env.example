# MediERP Professional - Configuration
# Copier ce fichier en .env et remplir les valeurs

# === SUPABASE (CLOUD) ===
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# === CRYPTOGRAPHIE ===
CRYPTO_KEY=your_32_char_encryption_key_here!!
SQLITE_CIPHER_KEY=your_db_cipher_key_here_32chars
JWT_SECRET=your_super_secret_jwt_key_here_64chars_long

# === BASE DE DONNÉES (LOCALE) ===
DB_PATH=./db/medierp_pro.db
DB_BACKUP_DIR=./db/backups

# === SMTP (Envoi ordonnances) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_app

# === ML CONFIG ===
ML_MODEL_PATH=./assets/models/heart_risk_model.pkl
ML_CONFIDENCE_THRESHOLD=0.7
ML_AUTO_PREDICT=true

# === LOGGING ===
LOG_LEVEL=INFO
LOG_DIR=./logs

# === APP CONFIG ===
APP_NAME=MediERP Professional
APP_VERSION=2.0.0
APP_THEME=light
